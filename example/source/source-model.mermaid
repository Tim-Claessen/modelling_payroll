    %% ============================================================
    %% SAP HCM SOURCE TABLES
    %% Personnel Administration (PA) Infotypes
    %% ============================================================

    %% All PA tables share common key: MANDT, PERNR, SUBTY, OBJPS, SPRPS, ENDDA, BEGDA, SEQNR

    PA0000 {
        CLNT MANDT PK "Client"
        NUMC PERNR PK "Personnel Number"
        CHAR SUBTY PK "Subtype"
        CHAR OBJPS PK "Object Identification"
        CHAR SPRPS "Lock Indicator"
        DATS ENDDA PK "End Date"
        DATS BEGDA PK "Start Date"
        NUMC SEQNR PK "Sequence Number"
        DATS AEDTM "Last Changed On"
        CHAR UNAME "Changed By"
        CHAR MASSN "Action Type"
        CHAR MASSG "Reason for Action"
        CHAR STAT2 "Employment Status"
        CHAR STAT1 "Status - Active/Inactive"
    }

    PA0001 {
        CLNT MANDT PK "Client"
        NUMC PERNR PK "Personnel Number"
        CHAR SUBTY PK "Subtype"
        CHAR OBJPS PK "Object Identification"
        CHAR SPRPS "Lock Indicator"
        DATS ENDDA PK "End Date"
        DATS BEGDA PK "Start Date"
        NUMC SEQNR PK "Sequence Number"
        DATS AEDTM "Last Changed On"
        CHAR UNAME "Changed By"
        CHAR BUKRS "Company Code"
        CHAR WERKS "Personnel Area"
        CHAR BTRTL "Personnel Subarea"
        CHAR PERSG "Employee Group"
        CHAR PERSK "Employee Subgroup"
        NUMC ORGEH "Organisational Unit"
        NUMC PLANS "Position"
        NUMC STELL "Job Key"
        CHAR KOSTL "Cost Center"
        CHAR ABKRS "Payroll Area"
        CHAR GSBER "Business Area"
        CHAR ANSVH "Work Contract"
        CHAR SACHA "Payroll Administrator"
        CHAR SACHP "HR Administrator"
        CHAR SACHZ "Time Administrator"
    }

    PA0002 {
        CLNT MANDT PK "Client"
        NUMC PERNR PK "Personnel Number"
