    %% ============================================================
    %% Time Management (PT) Infotypes
    %% ============================================================

    PA2001 {
        CLNT MANDT PK "Client"
        NUMC PERNR PK "Personnel Number"
        CHAR SUBTY PK "Subtype - Absence Type"
        CHAR OBJPS PK "Object Identification"
        CHAR SPRPS "Lock Indicator"
        DATS ENDDA PK "End Date"
        DATS BEGDA PK "Start Date"
        NUMC SEQNR PK "Sequence Number"
        DATS AEDTM "Last Changed On"
        CHAR UNAME "Changed By"
        CHAR AWART "Absence Type"
        DEC ABWTG "Absence Days"
        DEC ABSSTD "Absence Hours"
        DEC KVERB "Leave Deduction Days"
        CHAR STDAZ "Hours Deducted"
    }

    PA2002 {
        CLNT MANDT PK "Client"
        NUMC PERNR PK "Personnel Number"
        CHAR SUBTY PK "Subtype - Attendance Type"
        CHAR OBJPS PK "Object Identification"
        CHAR SPRPS "Lock Indicator"
        DATS ENDDA PK "End Date"
        DATS BEGDA PK "Start Date"
        NUMC SEQNR PK "Sequence Number"
        DATS AEDTM "Last Changed On"
        CHAR UNAME "Changed By"
        CHAR AWART "Attendance Type"
        DEC STDAZ "Number of Hours"
        TIMS BEGUZ "Start Time"
        TIMS ENDUZ "End Time"
        CHAR VTKEN "Previous Day Indicator"
    }

    PA2007 {
        CLNT MANDT PK "Client"
        NUMC PERNR PK "Personnel Number"
        CHAR SUBTY PK "Subtype - Quota Type"
        CHAR OBJPS PK "Object Identification"
        CHAR SPRPS "Lock Indicator"
        DATS ENDDA PK "End Date"
        DATS BEGDA PK "Start Date"
        NUMC SEQNR PK "Sequence Number"
        DATS AEDTM "Last Changed On"
        CHAR UNAME "Changed By"
        CHAR KTART "Quota Type"
        DEC ANZHL "Entitlement - Total Quota"
        DEC KVERB "Quota Used"
        DEC QUESTI "Quota Remaining"
        DATS QUESSION "Deduction From Date"
        DATS QUESSION2 "Deduction To Date"
    }

    %% ============================================================
    %% Wage Type Report (Pre-built extract)
    %% ============================================================

    WAGE_TYPE_REPORT {
        CLNT MANDT PK "Client"
        NUMC PERNR PK "Personnel Number"
        CHAR ABKRS "Payroll Area"
        DATS FPPER_BEG "For Period Start"
        DATS FPPER_END "For Period End"
        DATS IPPER_BEG "In Period Start"
        DATS IPPER_END "In Period End"
        DATS PAYDT "Payment Date"
        CHAR PAYTY "Pay Run Type"
        CHAR LGART PK "Wage Type"
        CHAR LGTXT "Wage Type Text"
        CURR BETRG "Amount"
        DEC ANZHL "Number - Units"
        CURR RATE "Rate"
        CHAR WAERS "Currency Key"
        CHAR KOSTL "Cost Center"
    }

    %% ============================================================
    %% RELATIONSHIPS
    %% All PA tables link on PERNR (Personnel Number)
    %% ============================================================

    PA0000 ||--|| PA0001 : "same employee"
    PA0000 ||--|| PA0002 : "same employee"
    PA0001 ||--|| PA0002 : "same employee"
    PA0001 ||--|{ PA0006 : "addresses"
    PA0001 ||--|{ PA0007 : "working time"
    PA0001 ||--|{ PA0008 : "basic pay"
    PA0001 ||--|{ PA0009 : "bank details"
    PA0001 ||--|{ PA2001 : "absences"
    PA0001 ||--|{ PA2002 : "attendances"
    PA0001 ||--|{ PA2007 : "leave quotas"
    PA0001 ||--|{ WAGE_TYPE_REPORT : "payroll results"
